# nu-ServiceDesk 환경 변수 (Design V2.1)
# .env.local로 복사하여 사용

# === Database ===
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/servicedesk?schema=public&connection_limit=10&pool_timeout=10"

# === Redis ===
REDIS_URL="redis://:your-redis-password@localhost:6379"
REDIS_PASSWORD="your-redis-password"

# === Session ===
# SESSION_SECRET은 현재 미사용 (세션 ID는 randomBytes로 생성, HMAC은 ROLE_HINT_SECRET 사용)
ROLE_HINT_SECRET="change-me-to-random-32-chars-or-more-rolehint"

# === Web Push (VAPID) ===
# 생성: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_EMAIL="mailto:admin@nu-servicedesk.com"

# === Cloudflare R2 ===
# R2_ENDPOINT 형식: https://{accountId}.r2.cloudflarestorage.com
R2_ENDPOINT=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME="nusd-files"
R2_PUBLIC_URL=""

# === App ===
NEXT_PUBLIC_APP_URL="http://localhost:3010"
BCRYPT_SALT_ROUNDS=12
TZ=Asia/Seoul
